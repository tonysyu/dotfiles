{
  "permissions": {
    "allow": [
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm test)",
      "Bash(npm test:*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsc:*)",
      "mcp__gitlab__get_file_contents",
      "mcp__ifl__listIFLComponents",
      "WebFetch(domain:docs.anthropic.com)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "plan"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Funk.aiff"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/tonyyu/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  }
}
